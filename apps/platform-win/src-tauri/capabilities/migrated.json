{
  "identifier": "migrated",
  "description": "permissions that were migrated from v1",
  "local": true,
  "windows": [
    "search-view","config-view"
  ],
  "permissions": [
    "core:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read-dir",
    "fs:allow-copy-file",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-app-write",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-exists",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-open",
    "dialog:allow-confirm",
    {
      "identifier": "fs:scope",
      "allow": [
        "$APPDATA/**"
      ]
    },
    "shell:allow-open",
    "fs:default",
    "core:window:allow-close",
    "core:window:allow-hide",
    "core:window:allow-minimize",
    "core:window:allow-start-dragging",
    "core:window:allow-set-always-on-top",
    "shell:default",
    {
      "identifier": "http:default",
      "allow": [{ "url": "http://**" },{"url":"https://**"}]
    }
  ]
}